          <mxGeometry height="70" width="380" x="970" y="1316" as="geometry" />
        </mxCell>
        <mxCell id="c1066" parent="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Lectura rapida para la presentacion" vertex="1">
          <mxGeometry height="26" width="1310" x="40" y="1506" as="geometry" />
        </mxCell>
        <mxCell id="c1067" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacing=8;" value="Alt. 1: la mas simple de implementar, menor curva de aprendizaje, pero concentra lectura y escritura en una sola BD y su auditoria depende de un log secundario." vertex="1">
          <mxGeometry height="40" width="1310" x="40" y="1536" as="geometry" />
        </mxCell>
        <mxCell id="c1068" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;spacing=8;" value="Alt. 2: resuelve trazabilidad y escalabilidad de lectura con Event Sourcing + CQRS, pero sin cache (sin latencia garantizada) ni blindaje especifico de WAF para trafico externo." vertex="1">
          <mxGeometry height="40" width="1310" x="40" y="1582" as="geometry" />
