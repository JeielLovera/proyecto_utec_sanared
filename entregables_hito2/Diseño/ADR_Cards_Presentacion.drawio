        <mxCell id="c2-ctx-body" value="&#8226; LIS y Portal de Pagos ya operan en Azure.&lt;br&gt;&#8226; Se requiere Cosmos DB, Elasticsearch y Databricks." style="text;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
