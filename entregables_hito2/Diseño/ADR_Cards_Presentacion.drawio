          <mxGeometry x="40" y="266" width="175" height="16" as="geometry" />
        </mxCell>
        <mxCell id="c1-good-body" value="Costos consolidados con el Portal existente. Servicios gestionados maduros (Aurora, EventBridge)." style="text;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;whiteSpace=wrap;fontColor=#2f6627;" vertex="1" parent="1">
          <mxGeometry x="40" y="282" width="175" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c1-risk-label" value="&#9888; RIESGO" style="text;html=1;fontStyle=1;fontSize=10;fontColor=#b85450;align=left;verticalAlign=middle;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="225" y="266" width="175" height="16" as="geometry" />
        </mxCell>
        <mxCell id="c1-risk-body" value="Certificacion en Aurora Multi-AZ y Step Functions. Latencia del HCE on-prem hacia AWS." style="text;html=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;whiteSpace=wrap;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="225" y="282" width="175" height="70" as="geometry" />
