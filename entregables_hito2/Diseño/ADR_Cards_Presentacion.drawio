        <mxCell id="tpl-ctx-label" value="CONTEXTO" style="text;html=1;fontStyle=1;fontSize=11;fontColor=#666666;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="148" width="200" height="16" as="geometry" />
        </mxCell>

        <mxCell id="tpl-ctx-body" value="&#8226; { Situacion o problema 1 }&lt;br&gt;&#8226; { Situacion o problema 2 }" style="text;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="166" width="360" height="55" as="geometry" />
