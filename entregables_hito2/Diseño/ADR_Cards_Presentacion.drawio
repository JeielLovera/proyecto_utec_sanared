        <mxCell id="tpl-decision" value="DECISION: { Frase unica que resume la decision tomada, en negrita }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
