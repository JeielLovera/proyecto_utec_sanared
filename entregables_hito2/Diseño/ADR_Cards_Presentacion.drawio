<mxfile host="app.diagrams.net" agent="Claude" version="21.6.5" type="device">
  <diagram id="plantilla-adr" name="1. Plantilla ADR">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="tpl-note" value="Duplica esta tarjeta (Ctrl+D), muevela y reemplaza el texto entre llaves { } por el contenido real de cada ADR. El color del header y el badge de estado pueden cambiar segun el ADR (ver leyenda abajo)." style="text;html=1;fontSize=12;fontStyle=2;fontColor=#666666;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="600" height="40" as="geometry" />
