        </mxCell>
        <mxCell id="c1-ctx-body" value="&#8226; Portal de Pacientes y App Movil ya operan en AWS.&lt;br&gt;&#8226; Se busca reducir la complejidad de multi-cloud." style="text;html=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="136" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="c1-decision" value="DECISION: AWS como cloud unico para el EMPI Core, Master DB, cache, ESB y orquestacion batch." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="198" width="360" height="60" as="geometry" />
