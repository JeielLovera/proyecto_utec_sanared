        <mxCell id="tpl-card" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#438dd5;strokeWidth=2;arcSize=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="380" height="320" as="geometry" />
        </mxCell>

        <mxCell id="tpl-header" value="{ADR-ID} &#8212; { Titulo corto de la decision }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168bd;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=13;align=left;verticalAlign=middle;spacingLeft=10;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="380" height="40" as="geometry" />
