{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanared.pe/empi/schemas/PatientRegistered.schema.json",
  "title": "PatientRegistered.payload",
  "description": "Alta de identidad nueva (Flujo A, RF-01). Payload FHIR-compatible (§2.2).",
  "type": "object",
  "additionalProperties": false,
  "required": ["empi_id", "identifiers", "name", "source_system"],
  "$defs": {
    "identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "type", "value"],
      "properties": {
        "system": { "type": "string", "format": "uri",
          "description": "URI canónico FHIR: urn:pe:reniec:dni, urn:sanared:hce, ..." },
        "type":   { "type": "string",
          "enum": ["DNI", "HIST", "MRN", "PID", "ACCESSION", "ACC", "SCHED-ID"] },
        "value":  { "type": "string", "minLength": 1, "maxLength": 64 },
        "use":    { "type": "string", "enum": ["official", "secondary", "old"] },
        "assigning_sede": { "type": "string" }
      }
    },
    "telecom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string", "enum": ["phone", "email"] },
        "value":  { "type": "string" },
        "use":    { "type": "string", "enum": ["mobile", "home", "work"] }
      }
    }
  },
  "properties": {
    "empi_id": { "type": "string", "pattern": "^EMPI-[0-9]{8}-[0-9A-F]{8}$" },
    "identifiers": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/identifier" },
      "description": "Crosswalk inicial: al menos el DNI y el ID del canal de alta."
    },
    "name": {
      "type": "object",
      "additionalProperties": false,
      "required": ["given", "family"],
      "properties": {
        "given":  { "type": "string" },
        "family": { "type": "string" }
      }
    },
    "birth_date": { "type": "string", "format": "date" },
    "gender": { "type": "string", "enum": ["male", "female", "other", "unknown"] },
    "telecom": { "type": "array", "items": { "$ref": "#/$defs/telecom" } },
    "verification_status": { "type": "string", "enum": ["VERIFICADO", "INCOMPLETO"] },
    "match_context": {
      "type": "object",
      "description": "Contexto del matching que llevó al alta (no-match).",
      "properties": {
        "method": { "type": "string" },
        "score":  { "type": "number", "minimum": 0, "maximum": 1 },
        "model_version": { "type": "string" }
      }
    },
    "source_system": {
      "type": "string",
      "enum": ["RENIEC", "HCE", "LIS", "PORTAL", "PACS", "ERP", "AGENDA"]
    }
  }
}
