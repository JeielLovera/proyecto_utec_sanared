{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanared.pe/empi/schemas/PatientMatchPending.schema.json",
  "title": "PatientMatchPending.payload",
  "description": "Par candidato encolado a revisión manual (Flujo B3, score 0.85-0.949) (§2.2, RF-02). Evento INTERNO: no cruza al bus.",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidate_pair_id", "empi_id_existing", "incoming_ref", "match_score", "band"],
  "properties": {
    "candidate_pair_id": { "type": "string", "format": "uuid" },
    "empi_id_existing": { "type": "string", "pattern": "^EMPI-[0-9]{8}-[0-9A-F]{8}$" },
    "incoming_ref": {
      "type": "string",
      "description": "Registro entrante en staging (aún no es golden record).",
      "examples": ["STG-2026-000481"]
    },
    "match_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "band": { "type": "string", "enum": ["REVIEW"] },
    "model_version": { "type": "string" },
    "features": {
      "type": "object",
      "description": "Vector de features del scoring (evidencia para el operador y para reentrenar §3.6).",
      "additionalProperties": false,
      "properties": {
        "jaro_winkler_name": { "type": "number", "minimum": 0, "maximum": 1 },
        "metaphone_match":   { "type": "boolean" },
        "dob_equal":         { "type": "boolean" },
        "phone_equal":       { "type": "boolean" },
        "dni_equal":         { "type": "boolean" }
      }
    }
  }
}
