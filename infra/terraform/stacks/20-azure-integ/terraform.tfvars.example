# Copia a terraform.tfvars y ajusta.
project         = "sanared-empi"
environment     = "demo"
subscription_id = "" # o export ARM_SUBSCRIPTION_ID / az login
location        = "eastus2"
vnet_cidr       = "10.30.0.0/16" # no solapar con AWS (10.20/16) ni GCP (10.40/16)
enable_apim     = true           # false para pruebas rápidas (APIM tarda ~30-45 min)

# Golden path cross-cloud real (opcional, requiere 10-aws-empi + 40-xcloud-net aplicados).
# Copia los 3 valores del output de 40-xcloud-net: bus_bootstrap_sasl_iam,
# kafka_xcloud_access_key_id, kafka_xcloud_secret_access_key (ver DEPLOYMENT.md).
enable_kafka_consumer = false
kafka_bootstrap       = ""
aws_access_key_id     = ""
aws_secret_access_key = ""
# Solo si usas credenciales TEMPORALES (AWS Academy Learner Lab, ~4h de vigencia) en vez
# de un usuario IAM dedicado (create_iam_roles=false no puede crear ese usuario). Sácalas
# de `aws configure list` / el panel "AWS Details" del lab.
aws_session_token = ""
